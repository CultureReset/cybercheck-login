{
  "buildCommand": null,
  "devCommand": null,
  "installCommand": null,
  "framework": null,
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/wavegent/:slug",
      "destination": "/api/wavegent/:slug"
    },
    {
      "source": "/p/:slug",
      "destination": "/biz.html"
    },
    {
      "source": "/book/:slug/:app",
      "destination": "/book.html"
    },
    {
      "source": "/waiver/:slug",
      "destination": "/waiver.html"
    },
    {
      "source": "/manage/:id",
      "destination": "/manage.html"
    },
    {
      "source": "/live/:slug",
      "destination": "/song-request.html?slug=:slug"
    },
    {
      "source": "/daily/:slug",
      "destination": "/menu-update.html?slug=:slug"
    },
    {
      "source": "/q/:code",
      "destination": "/q.html?c=:code"
    },
    {
      "source": "/widget/:slug",
      "destination": "/widget.html?slug=:slug"
    }
  ],
  "headers": [
    {
      "source": "/login.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    }
  ]
}